{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "artifacts/valentine-proposal/dist/public",
  "installCommand": "pnpm install",
  "functions": {
    "artifacts/api-server/src/index.ts": {
      "runtime": "vercel-node@3.1.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "artifacts/api-server/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
