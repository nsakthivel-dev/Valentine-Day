{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm build",
  "outputDirectory": "artifacts/valentine-proposal/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
